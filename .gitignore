# ── Project-specific ─────────────────────────────────────────────────────────
# Data files (too large / sensitive for git)
data/raw/
data/*.csv
data/*.zip
data/*.gz

# ML models (commit only metrics/metadata, not binary model files)
src/ml/models/*.pkl
src/ml/models/*.joblib

# Airflow runtime files
airflow/logs/
airflow/plugins/__pycache__/

# Dashboard binaries (commit screenshots instead)
dashboards/tableau/*.twbx
dashboards/powerbi/*.pbix

